/* pages/camera/camera.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh; /* 确保容器高度至少为屏幕高度 */
  box-sizing: border-box; /* 避免padding导致溢出 */
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin: 30rpx 0 20rpx 0;
  color: #333;
  border-left: 8rpx solid #007aff;
  padding-left: 16rpx;
}

.input-group {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  border: 1px solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.button-group {
  display: flex;
  justify-content: space-between;
  margin: 20rpx 0;
}

.button-group button {
  width: 48%;
}

/* 图像容器样式 */
.image-container {
  width: 100%;
  margin: 20rpx 0;
  border: 1px solid #ccc;
  border-radius: 8rpx;
  overflow: hidden;
  background-color: #f5f5f5;
}

/* 流图像样式 - 重要：控制尺寸避免覆盖全屏 */
.stream-image {
  width: 100%;
  height: auto;
  max-height: 600rpx; /* 限制最大高度 */
}

/* 占位符样式 */
.placeholder {
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  color: #999;
  font-size: 28rpx;
}

/* 提升控制面板的层级和布局 */
.control-section, .stream-section, .video-section {
  position: relative;
  margin-bottom: 40rpx;
}

.captured-image {
  width: 100%;
  margin-top: 20rpx;
  border-radius: 8rpx;
}